PORT=3000

# Provider: wikipedia | bing | google
SEARCH_PROVIDER=wikipedia

# Google Programmable Search (Custom Search JSON API)
# Note: Google docs now state this API is "not available for new customers" and is discontinued Jan 1, 2027.
GOOGLE_API_KEY=your_google_cloud_api_key_here
GOOGLE_CSE_ID=your_programmable_search_engine_id_here

# Bing Web Search API (recommended if Google blocks new projects)
BING_API_KEY=your_bing_subscription_key_here

